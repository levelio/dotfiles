# Font
font-family = JetBrainsMono Nerd Font Mono
font-size = 18

# Theme
theme = Mathias

# Background Image (随机壁纸)

# Local images are intentionally kept outside this repo.
# background-image = /Users/zhiqiang/.config/ghostty/wallpapers/Sunset-room.png
# background-image-fit = cover
# background-image-opacity = 0.5
# background-opacity = 1.0

# Window
maximize = true
window-padding-x = 8
window-padding-y = 4
window-inherit-working-directory = true
window-decoration = true

# Quick Terminal (下拉终端)
quick-terminal-position = top
quick-terminal-size = 60%

# Cursor
cursor-style = bar
cursor-style-blink = false

# Scrollback
scrollback-limit = 10000

# Mouse
mouse-hide-while-typing = false

# Misc
confirm-close-surface = false

# Leader key: Ctrl+A (tmux-style)
keybind = ctrl+a>minus=new_split:down
keybind = ctrl+a>backslash=new_split:right
keybind = ctrl+a>shift+left=resize_split:left,11
keybind = ctrl+a>shift+right=resize_split:right,10
keybind = ctrl+a>shift+up=resize_split:up,10
keybind = ctrl+a>shift+down=resize_split:down,10
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:down
keybind = ctrl+a>k=goto_split:up
keybind = ctrl+a>l=goto_split:right
keybind = ctrl+a>c=new_tab
keybind = ctrl+a>n=next_tab
keybind = ctrl+a>p=previous_tab
keybind = ctrl+a>1=goto_tab:1
keybind = ctrl+a>2=goto_tab:2
keybind = ctrl+a>3=goto_tab:3
keybind = ctrl+a>4=goto_tab:4
keybind = ctrl+a>5=goto_tab:5
keybind = ctrl+a>6=goto_tab:6
keybind = ctrl+a>7=goto_tab:7
keybind = ctrl+a>8=goto_tab:8
keybind = ctrl+a>9=goto_tab:9
keybind = ctrl+a>x=close_surface
keybind = ctrl+a>z=toggle_split_zoom
